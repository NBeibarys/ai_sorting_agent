# Service account JSON (relative path or absolute). The account's email needs
# Editor access on the target Google Sheet.
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Vertex AI — the pipeline uses Vertex, NOT the Gemini Developer API.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Source/destination sheet (output tabs are written back into THIS sheet).
SORTER_SHEET_ID=
SORTER_SHEET_RANGE=Form Responses 1

# Single classifier agent.
SORTER_MODEL=gemini-3.5-flash

# Batch.
MAX_CONCURRENCY=8
CHECKPOINT_PATH=checkpoint.json

# Column needles (substring match, case-insensitive, accent-folded). Change
# these if a future cohort rewords the form questions instead of editing code.
# Defaults below are for the Alchemist sheet (classify by country of
# INCORPORATION, not physical HQ).
SORTER_NAME_COLUMN=startup name
SORTER_COUNTRY_COLUMN=where is your startup incorporated
SORTER_FOUNDER_NAME_COLUMN=full name of your ceo
SORTER_EMAIL_COLUMN=ceo's email
SORTER_TELEGRAM_COLUMN=telegram account
SORTER_PITCH_DECK_COLUMN=pitch deck

# Human-readable label injected into the classifier/verifier prompts to
# describe the country field. "incorporated" for the Alchemist sheet
# (classify by country of incorporation); "physically headquartered" for the
# r2b sheet (classify by physical HQ country).
SORTER_COUNTRY_LABEL=incorporated

# Column to check for duplicates (substring match, case-insensitive, accent-folded).
# Rows with a duplicate value in this column (after whitespace-stripping, case-
# folded) keep ONLY the first occurrence; later duplicates are dropped before
# classification and never written to output tabs. Empty values are NOT
# duplicates. Leave blank to disable deduplication entirely.
DEDUP_COLUMN=Startup name

# Comma-separated display column names written to the header row of every
# output tab. The full source row (all columns) is copied verbatim into each
# output tab — one row per startup, every field — so this list must match the
# source sheet's column count and order. Listed below are all 16 Alchemist
# sheet columns. For the r2b sheet, replace with the 8-column r2b layout.
OUTPUT_COLUMNS=Timestamp,Email Address,Score,Startup Name,Which country do most of your team members come from?,Startup Website,What specific problem does your company solve for B2B customers?,What was your revenue in 2025 and 2026 (in USD)?,Pitch Deck Link,Video Pitch Link,CEO Full Name,CEO Email,CEO Telegram Account,Delaware Registered,VISA to USA,Where is your startup incorporated?
